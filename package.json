{
  "name": "social-worker-ai",
  "version": "1.0.0",
  "description": "AI - Human Crisis Monitoring Platform",
  "private": true,
  "workspaces": [
    "server",
    "chatbot",
    "dashboard"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=chatbot\" \"npm run dev --workspace=dashboard\"",
    "lint": "eslint '**/*.{js,jsx}' --ignore-path .gitignore",
    "format": "prettier --write '**/*.{js,jsx,json,css,md}' --ignore-path .gitignore",
    "test": "npm run test --workspace=server",
    "test:coverage": "npm run test --workspace=server -- --coverage",
    "prepare": "husky install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
