# Server
PORT=3000
NODE_ENV=development

# Database (MySQL 8+)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=social_worker_ai

# JWT
JWT_SECRET=
JWT_EXPIRY=24h

# Encryption (AES-256-CBC)
ENCRYPTION_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Launch Lemonade (primary AI)
LEMONADE_API_KEY=
LEMONADE_ASSISTANT_ID=1772822866868x782078534383128200
LEMONADE_AGENT_SOCIAL_WORKER_ID=
LEMONADE_AGENT_SEARCH_ID=
LEMONADE_AGENT_COMMS_ID=
LEMONADE_AGENT_AUDIT_ID=

# Anthropic Claude (backup AI)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI Provider (proxy mode — company's AI)
# Set AI_PROVIDER to 'openai' or 'mistral' (auto-detects from API key if not set)
AI_PROVIDER=
AI_MODEL=
AI_SYSTEM_PROMPT=You are a friendly and helpful AI study assistant called "60 Watts of Intelligence". You help students with homework, study tips, and learning. Keep responses concise and encouraging. You are speaking with a teenager.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SYSTEM_PROMPT=

# Mistral
MISTRAL_API_KEY=
# Models: mistral-small-latest, mistral-large-latest, mistral-medium-latest

# Twilio (SMS + voice alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MONITOR_PHONE=

# SendGrid (email alerts)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_MONITOR_EMAIL=
